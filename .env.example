# ============================================================
# CapstoneX — Master Environment Variables Reference
# Copy this file to .env and fill in your values
# ============================================================

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://capstonex:capstonex_pass@localhost:5432/capstonex_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=capstonex_db
DB_USER=capstonex
DB_PASS=capstonex_pass

# ---- Backend (Express.js) ----
NODE_ENV=development
PORT=5000
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
FRONTEND_URL=http://localhost:3000

# ---- Firebase ----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@capstonex.com

# ---- AI Service (FastAPI) ----
AI_SERVICE_URL=http://localhost:8000
AI_INTERNAL_SECRET=your-ai-internal-secret-min-8-chars

# ---- AI/ML Configuration ----
LLM_PROVIDER=fallback
# Set to 'openai' and provide key for GPT-4o powered features:
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=all-MiniLM-L6-v2
HUGGINGFACE_TOKEN=your-huggingface-token

# ---- Redis (Optional — caching for embeddings/predictions) ----
# REDIS_URL=redis://localhost:6379/0

# ---- Model Training ----
MIN_TRAINING_SAMPLES=50
SHAP_ENABLED=true
MODEL_REGISTRY_ENABLED=true

# ---- GitHub Integration (Optional) ----
# GITHUB_TOKEN=your-github-personal-access-token

# ---- Monitoring (Optional) ----
# PROMETHEUS_ENABLED=false

# ---- PgAdmin ----
PGADMIN_EMAIL=admin@capstonex.com
PGADMIN_PASSWORD=admin123
